    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "vue3-toastify": "^0.2.9",
    "zod": "^3.25.76"
